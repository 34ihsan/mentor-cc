# Database (Production uses PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/starberatung?schema=public"

# Next Auth (Critical for Login)
AUTH_SECRET="your-secret-key-min-32-chars"
# NEXTAUTH_URL="https://your-domain.com" # Use on VPS

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email Configuration (Nodemailer)
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT=465
SMTP_USER="info@your-domain.com"
SMTP_PASS="your-password"
SMTP_FROM="Star Beratung <info@your-domain.com>"

# Google Auth (Optional but recommended)
# GOOGLE_ID=""
# GOOGLE_SECRET=""

# Internationalization
DEFAULT_LOCALE="tr"

# reCAPTCHA Configuration
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="your-recaptcha-site-key"
RECAPTCHA_SECRET_KEY="your-recaptcha-secret-key"
