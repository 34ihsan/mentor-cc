# Database
DATABASE_URL="postgresql://user:pass@localhost:5432/db"

# Auth
AUTH_SECRET="your-auth-secret"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
AUTH_TRUST_HOST=true
AUTH_URL="http://localhost:3000/api/auth"

# SMTP
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="info@example.com"
SMTP_PASS="password"

# Meta / Instagram
META_VERIFY_TOKEN="verify_token"
META_PAGE_ACCESS_TOKEN="access_token"
META_APP_SECRET="app_secret"

# OpenRouter (AI)
OPENROUTER_API_KEY="your-openrouter-key"
OPENROUTER_IMAGE_MODEL="black-forest-labs/flux.2-pro"
OPENROUTER_TEXT_MODEL="google/gemini-2.0-flash-exp:free"
OPENROUTER_MODEL_SEQUENCE="google/gemma-4-31b-it:free,qwen/qwen3-next-80b-a3b-instruct:free,qwen/qwen3-coder:free,google/gemini-2.0-flash-exp:free"

# reCAPTCHA (Optional for dev, required for prod)
RECAPTCHA_SECRET_KEY="your-recaptcha-secret-key"
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="your-recaptcha-site-key"

# GDPR Cron Job Secret (generate a strong random string)
CRON_SECRET="your-strong-random-secret-here"
